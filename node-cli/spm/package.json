{
  "name": "spm-versions",
  "version": "1.0.0",
  "private": true,
  "description": "Find installable versions of a Swift package from a git repository.",
  "type": "module",
  "bin": {
    "spm-versions": "cli.mjs"
  },
  "main": "sdk.mjs",
  "scripts": {
    "start": "node cli.mjs",
    "check": "node --check main.mjs && node --check sdk.mjs && node --check cli.mjs",
    "smoke": "node main.mjs --help >/dev/null && node -e \"import('./sdk.mjs').then(s=>{const x=s.SpmVersionsSDK.fromArgv(['https://github.com/apple/swift-argument-parser.git','--limit','3','--first-only','-v']);if(x.config.package!=='https://github.com/apple/swift-argument-parser.git'||x.config.limit!==3||x.config.verbose!==true)process.exit(1);console.log('sdk OK')})\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {}
}

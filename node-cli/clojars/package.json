{
  "name": "clojars-versions",
  "version": "1.0.0",
  "private": true,
  "description": "Find resolvable versions of an artifact from Clojars (or a Maven repo).",
  "type": "module",
  "bin": {
    "clojars-versions": "cli.mjs"
  },
  "main": "sdk.mjs",
  "scripts": {
    "start": "node cli.mjs",
    "check": "node --check main.mjs && node --check sdk.mjs && node --check cli.mjs",
    "smoke": "node main.mjs --help >/dev/null && node -e \"import('./sdk.mjs').then(s=>{const x=s.ClojarsVersionsSDK.fromArgv(['org.clojure:clojure','--limit','3','--first-only','-v']);if(x.config.package!=='org.clojure:clojure'||x.config.limit!==3||x.config.verbose!==true)process.exit(1);console.log('sdk OK')})\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {}
}
